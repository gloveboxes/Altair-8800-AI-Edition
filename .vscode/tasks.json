{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "Altair: Start Local Altair - Windows",
      "type": "process",
      "command": "cmd.exe",
      "args": [
        "/d",
        "/c",
        "${workspaceFolder}/scripts/start-local-altair-windows.cmd"
      ],
      "options": {
        "cwd": "${workspaceFolder}"
      },
      "problemMatcher": [],
      "presentation": {
        "echo": true,
        "reveal": "always",
        "focus": true,
        "panel": "dedicated",
        "clear": true
      }
    },
    {
      "label": "Altair: Switch config to Waveshare 3.5B AXS15231B",
      "type": "shell",
      "command": "source \"$HOME/.espressif/v6.0.1/esp-idf/export.sh\" >/dev/null && rm -f sdkconfig && idf.py -D SDKCONFIG_DEFAULTS=\"sdkconfig.defaults;sdkconfig.WAVESHARE-ESP32-S3-Touch-LCD-3.5B.defaults\" reconfigure",
      "options": {
        "cwd": "${workspaceFolder}"
      },
      "problemMatcher": [],
      "group": "build",
      "presentation": {
        "reveal": "always",
        "panel": "dedicated",
        "clear": true
      }
    },
    {
      "label": "Altair: Switch config to Freenove ESP32-S3 LCD 2.8",
      "type": "shell",
      "command": "source \"$HOME/.espressif/v6.0.1/esp-idf/export.sh\" >/dev/null && rm -f sdkconfig && idf.py -D SDKCONFIG_DEFAULTS=\"sdkconfig.defaults;sdkconfig.FREENOVE-ESP32-S3-LCD-2.8.defaults\" reconfigure",
      "options": {
        "cwd": "${workspaceFolder}"
      },
      "problemMatcher": [],
      "group": "build",
      "presentation": {
        "reveal": "always",
        "panel": "dedicated",
        "clear": true
      }
    },
    {
      "label": "Altair: Switch config to Lonely Binary Altair Kit",
      "type": "shell",
      "command": "source \"$HOME/.espressif/v6.0.1/esp-idf/export.sh\" >/dev/null && rm -f sdkconfig && idf.py -D SDKCONFIG_DEFAULTS=\"sdkconfig.defaults;sdkconfig.LONELY_BINARY_ALTAIR_KIT.defaults\" reconfigure",
      "options": {
        "cwd": "${workspaceFolder}"
      },
      "problemMatcher": [],
      "group": "build",
      "presentation": {
        "reveal": "always",
        "panel": "dedicated",
        "clear": true
      }
    },
    {
      "label": "Altair: Switch config to Seeed XIAO ESP32-S3 Altair Kit",
      "type": "shell",
      "command": "source \"$HOME/.espressif/v6.0.1/esp-idf/export.sh\" >/dev/null && rm -f sdkconfig && idf.py -D SDKCONFIG_DEFAULTS=\"sdkconfig.defaults;sdkconfig.SEEED_XIAO_ESP32_S3.defaults\" reconfigure",
      "options": {
        "cwd": "${workspaceFolder}"
      },
      "problemMatcher": [],
      "group": "build",
      "presentation": {
        "reveal": "always",
        "panel": "dedicated",
        "clear": true
      }
    },
    {
      "label": "Altair: Flash Altair disk images",
      "type": "shell",
      "command": "source \"$HOME/.espressif/v6.0.1/esp-idf/export.sh\" >/dev/null && idf.py storage-flash",
      "options": {
        "cwd": "${workspaceFolder}"
      },
      "problemMatcher": [],
      "group": "build",
      "presentation": {
        "reveal": "always",
        "panel": "dedicated",
        "clear": true
      }
    },
    {
      "label": "Altair: Start Local Altair - macOS/Linux",
      "type": "shell",
      "command": "cmake -S altair_local -B altair_local/build && cmake --build altair_local/build && ./altair_local/build/altair-local",
      "options": {
        "cwd": "${workspaceFolder}"
      },
      "problemMatcher": [
        "$gcc"
      ],
      "presentation": {
        "echo": true,
        "reveal": "always",
        "focus": true,
        "panel": "dedicated",
        "clear": true
      }
    }
  ]
}